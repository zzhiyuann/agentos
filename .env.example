# AgentOS Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ───────────────────────────────────────────
# Required
# ───────────────────────────────────────────

# Linear workspace team UUID
# Find it: Linear > Settings > Workspace > General > Workspace ID
AOS_LINEAR_TEAM_ID=your-linear-team-uuid

# Linear team key prefix (the prefix on your issue IDs, e.g., "ENG" if your issues are ENG-1, ENG-2)
AOS_LINEAR_TEAM_KEY=ENG

# Execution host — where agent tmux sessions run
# Use "localhost" for local execution, or an IP/hostname for remote (SSH-based) execution
AOS_HOST=localhost

# Your username on the execution host (used for SSH when AOS_HOST is not localhost)
AOS_USER=your-username

# ───────────────────────────────────────────
# Optional — Workspace & Runtime
# ───────────────────────────────────────────

# Base directory for agent workspaces (default: ~/agent-workspaces)
# Each issue gets its own workspace directory under this path
AOS_WORKSPACE_BASE=~/agent-workspaces

# Monitor loop polling interval in milliseconds (default: 30000)
# How often the session monitor checks for HANDOFF.md and other artifacts
AOS_POLL_INTERVAL_MS=30000

# ───────────────────────────────────────────
# Optional — Security
# ───────────────────────────────────────────

# Webhook signature verification secret (recommended for production)
# Get this from Linear: Settings > API > Webhooks > Signing secret
# When set, AgentOS verifies HMAC-SHA256 signatures on incoming webhooks
AOS_WEBHOOK_SECRET=

# ───────────────────────────────────────────
# Optional — Organization Context
# ───────────────────────────────────────────

# Organization name (used in agent prompts for context)
AOS_ORG_NAME=My Company

# Source control URL (used in agent prompts)
AOS_SOURCE_CONTROL=github.com/your-org

# ───────────────────────────────────────────
# Optional — Notifications
# ───────────────────────────────────────────

# Discord bot token and channel for agent notifications
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Telegram bot token and chat ID for notifications (alternative to Discord)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
