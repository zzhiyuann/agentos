# AgentOS Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ──── Required ────

# Linear integration
AOS_LINEAR_TEAM_ID=your-linear-team-uuid
AOS_LINEAR_TEAM_KEY=YOUR_TEAM_KEY

# Execution host (the machine where agent sessions run)
AOS_HOST=localhost
AOS_USER=your-username

# ──── Optional ────

# Base directory for agent workspaces (default: ~/agent-workspaces)
AOS_WORKSPACE_BASE=~/agent-workspaces

# Monitor loop polling interval in ms (default: 30000)
AOS_POLL_INTERVAL_MS=30000

# Webhook signature verification (recommended for production)
# Get this from Linear: Settings > API > Webhooks > Signing secret
AOS_WEBHOOK_SECRET=

# Organization context (used in agent prompts)
AOS_ORG_NAME=Your Organization Name
AOS_SOURCE_CONTROL=github.com/your-org

# Discord notifications (optional)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
